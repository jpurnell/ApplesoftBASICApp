10 REM ================================
20 REM   HI-RES DRAWING DEMO
30 REM   280x192 GRAPHICS
40 REM ================================
50 HGR2
60 REM -- SPIRAL --
70 HCOLOR= 1
80 LET CX = 140: LET CY = 96
90 FOR A = 0 TO 720
100  LET R = A / 8
110  LET X = INT(COS(A * 3.14159 / 180) * R + CX)
120  LET Y = INT(SIN(A * 3.14159 / 180) * R + CY)
130  IF X < 0 OR X > 279 THEN 160
140  IF Y < 0 OR Y > 191 THEN 160
150  HPLOT X,Y
160 NEXT A
170 FOR T = 1 TO 500: NEXT T
180 REM -- BOX FRAME --
190 HGR2
200 HCOLOR= 6
210 HPLOT 10,10 TO 269,10
220 HPLOT 269,10 TO 269,181
230 HPLOT 269,181 TO 10,181
240 HPLOT 10,181 TO 10,10
250 REM -- INNER X --
260 HCOLOR= 5
270 HPLOT 10,10 TO 269,181
280 HPLOT 269,10 TO 10,181
290 REM -- CIRCLE APPROXIMATION --
300 HCOLOR= 2
310 FOR A = 0 TO 360 STEP 5
320  LET X = INT(COS(A * 3.14159 / 180) * 80 + 140)
330  LET Y = INT(SIN(A * 3.14159 / 180) * 80 + 96)
340  IF A = 0 THEN HPLOT X,Y
350  IF A > 0 THEN HPLOT TO X,Y
360 NEXT A
370 FOR T = 1 TO 800: NEXT T
380 TEXT
390 PRINT "HI-RES DRAWING COMPLETE!"
400 END
