10 REM ================================
20 REM   GRAPHICS DEMO
30 REM   LO-RES AND HI-RES
40 REM ================================
50 GR
60 REM -- RAINBOW BARS --
70 FOR C = 0 TO 15
80   COLOR= C
90   VLIN 0,47 AT C * 2
100  VLIN 0,47 AT C * 2 + 1
110 NEXT C
120 REM -- PAUSE --
130 FOR T = 1 TO 500: NEXT T
140 REM -- CHECKERBOARD --
150 FOR Y = 0 TO 39
160   FOR X = 0 TO 39
170     IF X + Y - INT((X + Y) / 2) * 2 = 0 THEN COLOR= 15
180     IF X + Y - INT((X + Y) / 2) * 2 = 1 THEN COLOR= 4
190     PLOT X,Y
200   NEXT X
210 NEXT Y
220 FOR T = 1 TO 500: NEXT T
230 REM -- HI-RES STARBURST --
240 HGR2
250 FOR A = 0 TO 35
260   LET HC = INT(A / 6) + 1
265   IF HC = 4 THEN HC = 5
270   HCOLOR= HC
280   LET X = INT(COS(A * 10 * 3.14159 / 180) * 90 + 140)
290   LET Y = INT(SIN(A * 10 * 3.14159 / 180) * 90 + 96)
300   HPLOT 140,96 TO X,Y
310 NEXT A
320 END
