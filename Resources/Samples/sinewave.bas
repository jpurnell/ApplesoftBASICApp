10 REM ================================
20 REM   SINE WAVE ART
30 REM   ASCII GRAPHICS DEMO
40 REM ================================
50 HOME
60 PRINT "** SINE WAVE ART **"
70 PRINT
80 REM -- SCROLLING SINE WAVE --
90 PRINT "SINE WAVE:"
100 PRINT
110 FOR Y = 0 TO 50
120   X = INT(SIN(Y / 5) * 15 + 20)
130   FOR S = 1 TO X
140     PRINT " ";
150   NEXT S
160   PRINT "*"
170 NEXT Y
180 PRINT
190 REM -- DUAL WAVE INTERFERENCE --
200 PRINT "WAVE INTERFERENCE:"
210 PRINT
220 FOR Y = 0 TO 40
230   X1 = INT(SIN(Y / 4) * 12 + 18)
240   X2 = INT(COS(Y / 3) * 12 + 18)
270   FOR S = 1 TO 38
275     C$ = "."
280     IF S = X1 AND S = X2 THEN C$ = "X"
285     IF S = X1 AND C$ = "." THEN C$ = "O"
290     IF S = X2 AND C$ = "." THEN C$ = "+"
310     PRINT C$;
320   NEXT S
330   PRINT
340 NEXT Y
350 PRINT
360 REM -- ASCII BAR CHART --
370 PRINT "MONTHLY APPLE SALES (1977):"
380 PRINT
390 DATA 2,3,5,7,12,18,25,35,42,50,65,80
400 FOR M = 1 TO 12
410   READ V
420   IF M < 10 THEN PRINT " ";
430   PRINT M;": ";
440   B = INT(V / 3)
450   FOR S = 1 TO B
460     PRINT "#";
470   NEXT S
480   PRINT " ";V
490 NEXT M
500 PRINT
510 PRINT "APPLE II LAUNCHED JUNE 1977!"
520 END
