510 PRINT : PRINT "INVENTORY:"
520 IF IT(1) = 1 THEN PRINT "  - CIRCUIT BOARD"
530 IF IT(2) = 1 THEN PRINT "  - 6502 PROCESSOR"
540 IF IT(3) = 1 THEN PRINT "  - POWER SUPPLY"
550 IF IT(4) = 1 THEN PRINT "  - KEYBOARD"
560 IF IT(5) = 1 THEN PRINT "  - BASIC ROM"
570 IF SC = 0 THEN PRINT "  (EMPTY)"
580 PRINT
590 RETURN
600 REM -- CHECK WIN --
610 IF SC >= 5 THEN GOTO 9000
620 RETURN
1000 REM ================================
1010 REM   ROOM 1: THE GARAGE
1020 REM ================================
1030 HOME
