1200 IF A$ = "G" OR A$ = "g" THEN GOTO 1300
1210 IF A$ = "E" OR A$ = "e" THEN RM = 2: GOTO 190
1220 IF A$ = "S" OR A$ = "s" THEN RM = 3: GOTO 190
1230 IF A$ = "I" OR A$ = "i" THEN GOSUB 500: GOTO 1170
1240 PRINT "HUH?": GOTO 1170
1300 REM -- GRAB CIRCUIT BOARD --
1310 IF IT(1) = 1 THEN PRINT "ALREADY HAVE IT!": GOTO 1170
