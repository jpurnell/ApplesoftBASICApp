10 REM ================================
20 REM   MUSIC AND SOUND DEMO
30 REM   BEEP, SOUND, AND MELODIES
40 REM ================================
50 PRINT "** SOUND DEMO **"
60 PRINT
70 REM -- SCALE --
80 PRINT "MUSICAL SCALE:"
90 DATA 262,294,330,349,392,440,494,523
100 DATA "C","D","E","F","G","A","B","C"
110 FOR I = 1 TO 8
120  READ F
130  SOUND F,0.3
140  FOR T = 1 TO 200: NEXT T
150 NEXT I
160 RESTORE
170 FOR I = 1 TO 8: READ F: NEXT I
180 FOR I = 1 TO 8
190  READ N$
200  PRINT N$;" ";
210 NEXT I
220 PRINT
230 PRINT
240 FOR T = 1 TO 300: NEXT T
250 REM -- SIREN --
260 PRINT "SIREN:"
270 FOR R = 1 TO 3
280  FOR F = 400 TO 800 STEP 50
290    SOUND F,0.05
300    FOR T = 1 TO 20: NEXT T
310  NEXT F
320  FOR F = 800 TO 400 STEP -50
330    SOUND F,0.05
340    FOR T = 1 TO 20: NEXT T
350  NEXT F
360 NEXT R
370 PRINT
380 REM -- HAPPY BIRTHDAY MELODY --
390 PRINT "HAPPY BIRTHDAY (MELODY):"
400 PRINT
410 REM C C D C F E
420 SOUND 262,0.3: FOR T = 1 TO 100: NEXT T
430 SOUND 262,0.15: FOR T = 1 TO 50: NEXT T
440 SOUND 294,0.4: FOR T = 1 TO 100: NEXT T
450 SOUND 262,0.4: FOR T = 1 TO 100: NEXT T
460 SOUND 349,0.4: FOR T = 1 TO 100: NEXT T
470 SOUND 330,0.6: FOR T = 1 TO 200: NEXT T
480 REM C C D C G F
490 SOUND 262,0.3: FOR T = 1 TO 100: NEXT T
500 SOUND 262,0.15: FOR T = 1 TO 50: NEXT T
510 SOUND 294,0.4: FOR T = 1 TO 100: NEXT T
520 SOUND 262,0.4: FOR T = 1 TO 100: NEXT T
530 SOUND 392,0.4: FOR T = 1 TO 100: NEXT T
540 SOUND 349,0.6: FOR T = 1 TO 200: NEXT T
550 PRINT "HAPPY BIRTHDAY, APPLE!"
560 BEEP
570 END
