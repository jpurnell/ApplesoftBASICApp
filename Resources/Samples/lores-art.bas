10 REM ================================
20 REM   LO-RES ART GALLERY
30 REM   APPLE II COLOR GRAPHICS
40 REM ================================
50 GR
60 REM -- DRAW ALL 16 COLORS --
70 FOR C = 0 TO 15
80   COLOR= C
90   HLIN 0,39 AT C * 3
100  HLIN 0,39 AT C * 3 + 1
110  HLIN 0,39 AT C * 3 + 2
120 NEXT C
130 FOR T = 1 TO 800: NEXT T
140 REM -- CONCENTRIC DIAMONDS --
150 GR
160 FOR R = 0 TO 19
170   COLOR= R - INT(R / 16) * 16
180   LET CX = 20: LET CY = 24
190   HLIN CX - R, CX + R AT CY - R
200   HLIN CX - R, CX + R AT CY + R
210   VLIN CY - R, CY + R AT CX - R
220   VLIN CY - R, CY + R AT CX + R
230 NEXT R
240 FOR T = 1 TO 800: NEXT T
250 REM -- RANDOM PIXEL ART --
260 GR
270 FOR I = 1 TO 500
280   COLOR= INT(RND(1) * 16)
290   PLOT INT(RND(1) * 40), INT(RND(1) * 48)
300 NEXT I
310 FOR T = 1 TO 800: NEXT T
320 TEXT
330 PRINT "LO-RES ART GALLERY COMPLETE!"
340 END
