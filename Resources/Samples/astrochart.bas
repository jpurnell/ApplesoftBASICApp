10 REM ================================
20 REM   ASTROCHART - ALL-ONE FARM
30 REM   PLANETARY COORDINATE SYSTEM
40 REM   AUGUST 1975
50 REM   CONV: 71/4068  EPOCH: B1950
60 REM ================================
70 HOME
80 REM -- CONSTANTS --
90 JR = 71 / 4068: REM JOBS RADIAN CONV
100 OB = 23.439: REM OBLIQUITY
110 PI = 3.14159
120 DIM PN$(6),PL(6),PS$(6),PD(6)
130 DIM ZN$(11),ZS$(11)
140 DIM L0(6),RT(6)
150 REM -- ZODIAC SIGNS --
160 ZS$(0) = "ARI":ZS$(1) = "TAU"
170 ZS$(2) = "GEM":ZS$(3) = "CAN"
180 ZS$(4) = "LEO":ZS$(5) = "VIR"
190 ZS$(6) = "LIB":ZS$(7) = "SCO"
200 ZS$(8) = "SAG":ZS$(9) = "CAP"
210 ZS$(10) = "AQU":ZS$(11) = "PIS"
220 REM -- PLANET NAMES --
230 PN$(0) = "SUN":PN$(1) = "MOON"
240 PN$(2) = "MERCURY":PN$(3) = "VENUS"
250 PN$(4) = "MARS":PN$(5) = "JUPITER"
260 PN$(6) = "SATURN"
270 REM -- MEAN ELEMENTS B1950 --
280 L0(0) = 279.46:RT(0) = .9856
290 L0(1) = 270.43:RT(1) = 13.176
300 L0(2) = 178.18:RT(2) = 4.092
310 L0(3) = 75.78:RT(3) = 1.602
320 L0(4) = 294.26:RT(4) = .524
330 L0(5) = 221.81:RT(5) = .083
340 L0(6) = 174.76:RT(6) = .034
350 REM ================================
360 REM   TITLE SCREEN
370 REM ================================
380 HOME
390 VTAB 4
400 PRINT TAB(9);"* ASTROCHART *"
410 PRINT
420 PRINT TAB(6);"ALL-ONE FARM DESIGN"
430 PRINT TAB(10);"AUGUST 1975"
440 PRINT
450 PRINT TAB(4);"PLANETARY COORDINATES"
460 PRINT
470 PRINT TAB(4);"TRIG CONV: 71/4068"
480 PRINT TAB(4);"EPOCH: B1950.0"
490 PRINT
500 PRINT TAB(3);"-----------------------"
510 PRINT TAB(3);"'WHERE ARE THE STARS?'"
520 PRINT TAB(3);"-----------------------"
530 PRINT
540 VTAB 22
550 PRINT "PRESS ANY KEY...";
560 GET A$
570 REM ================================
580 REM   INPUT BIRTH DATA
590 REM ================================
600 HOME
610 PRINT "ASTROCHART - DATA INPUT"
620 PRINT "======================="
630 PRINT
640 REM -- DEFAULT: STEVE JOBS --
650 YR = 1955:MO = 2:DY = 24
660 HR = 19:MI = 15
670 LA = 37.77:LO = -122.42
680 PRINT "DEFAULT: S.JOBS"
690 PRINT "  02/24/1955 19:15"
700 PRINT "  SAN FRANCISCO CA"
710 PRINT
720 PRINT "USE DEFAULT? (Y/N) ";
730 GET A$:PRINT A$
740 IF A$ = "Y" OR A$ = "y" THEN 870
750 PRINT
760 INPUT "YEAR (1900-2000): ";YR
770 INPUT "MONTH (1-12): ";MO
780 INPUT "DAY (1-31): ";DY
790 INPUT "HOUR (0-23): ";HR
800 INPUT "MINUTE (0-59): ";MI
810 PRINT
820 INPUT "LATITUDE (+N -S): ";LA
830 INPUT "LONGITUDE (+E -W): ";LO
840 REM ================================
850 REM   CALCULATIONS
860 REM ================================
870 HOME
880 PRINT "COMPUTING..."
890 PRINT
900 REM -- ABSOLUTE DAY FROM B1950 --
910 Y = YR:M = MO
920 IF M <= 2 THEN Y = Y - 1:M = M + 12
930 YD = Y - 1950
940 LP = INT(YD / 4)
950 REM -- MONTH DAYS TABLE --
960 MD = 0
970 IF M >= 2 THEN MD = 31
980 IF M >= 3 THEN MD = 59
990 IF M >= 4 THEN MD = 90
1000 IF M >= 5 THEN MD = 120
1010 IF M >= 6 THEN MD = 151
1020 IF M >= 7 THEN MD = 181
1030 IF M >= 8 THEN MD = 212
1040 IF M >= 9 THEN MD = 243
1050 IF M >= 10 THEN MD = 273
1060 IF M >= 11 THEN MD = 304
1070 IF M >= 12 THEN MD = 334
1080 REM -- TOTAL DAYS --
1090 TD = YD * 365 + LP + MD + DY
1100 FD = (HR + MI / 60) / 24
1110 AD = TD + FD
1120 REM -- SIDEREAL TIME --
1130 GS = 99 + AD * 360.9856
1140 NR = GS:GOSUB 3000:GS = NR
1150 LS = GS + LO
1160 NR = LS:GOSUB 3000:LS = NR
1170 REM -- MIDHEAVEN --
1180 MC = LS
1190 REM -- ASCENDANT --
1200 LR = LS * JR
1210 LT = LA * JR
1220 OBR = OB * JR
1230 CL = COS(LR):SL = SIN(LR)
1240 CO = COS(OBR):SO = SIN(OBR)
1250 TL = TAN(LT)
1260 IF ABS(TL) > 100 THEN TL = SGN(TL) * 100
1270 Y1 = -CL
1280 X1 = SL * CO + TL * SO
1290 IF X1 = 0 THEN X1 = .0001
1300 AR = ATN(Y1 / X1)
1310 IF X1 < 0 THEN AR = AR + PI
1320 AS = AR / JR
1330 NR = AS:GOSUB 3000:AS = NR
1340 REM -- PLANETARY POSITIONS --
1350 FOR I = 0 TO 6
1360   PL(I) = L0(I) + RT(I) * AD
1370   REM -- MOON EVECTION --
1380   IF I = 1 THEN PL(I) = PL(I) + 6 * SIN((PL(I) - 270) * JR)
1390   NR = PL(I):GOSUB 3000:PL(I) = NR
1400   ZI = INT(PL(I) / 30)
1410   IF ZI > 11 THEN ZI = 11
1420   IF ZI < 0 THEN ZI = 0
1430   PS$(I) = ZS$(ZI)
1440   PD(I) = PL(I) - ZI * 30
1450 NEXT I
1460 REM ================================
1470 REM   DISPLAY RESULTS
1480 REM ================================
1490 HOME
1500 PRINT "ASTROCHART RESULTS"
1510 PRINT "=================="
1520 PRINT
1530 PRINT "DATE: ";MO;"/";DY;"/";YR
1540 PRINT "TIME: ";HR;":";
1550 IF MI < 10 THEN PRINT "0";
1560 PRINT MI
1570 PRINT "LAT:";LA;" LONG:";LO
1580 PRINT
1590 PRINT "ABS.DAY:"; INT(AD);" (B1950)"
1600 PRINT "LST: "; INT(LS);"D "; INT((LS - INT(LS)) * 60);"M"
1610 PRINT
1620 PRINT "BODY     LONG  SIGN DEG"
1630 PRINT "------------------------"
1640 REM -- ASC --
1650 ZI = INT(AS / 30)
1660 IF ZI > 11 THEN ZI = 11
1670 IF ZI < 0 THEN ZI = 0
1680 DG = AS - ZI * 30
1690 PRINT "ASC      ";
1700 PRINT INT(AS);
1710 PRINT TAB(14);ZS$(ZI);
1720 DM = INT((DG - INT(DG)) * 60)
1730 PRINT TAB(18); INT(DG);"'";DM
1740 REM -- MC --
1750 ZI = INT(MC / 30)
1760 IF ZI > 11 THEN ZI = 11
1770 IF ZI < 0 THEN ZI = 0
1780 DG = MC - ZI * 30
1790 PRINT "MC       ";
1800 PRINT INT(MC);
1810 PRINT TAB(14);ZS$(ZI);
1820 DM = INT((DG - INT(DG)) * 60)
1830 PRINT TAB(18); INT(DG);"'";DM
1840 PRINT "------------------------"
1850 REM -- PLANETS --
1860 FOR I = 0 TO 6
1870   NM$ = PN$(I) + "        "
1880   PRINT LEFT$(NM$,8);
1890   PRINT INT(PL(I));
1900   PRINT TAB(14);PS$(I);
1910   DM = INT((PD(I) - INT(PD(I))) * 60)
1920   PRINT TAB(18); INT(PD(I));"'";DM
1930 NEXT I
1940 PRINT "------------------------"
1950 PRINT "ERROR: +/- 2-3 DEG"
1960 PRINT
1970 PRINT "'BECAUSE IT IS.' -1975"
1980 PRINT
1990 VTAB 23
2000 PRINT "AGAIN? (Y/N) ";
2010 GET A$:PRINT A$
2020 IF A$ = "Y" OR A$ = "y" THEN 600
2030 HOME
2040 PRINT "ALL-ONE FARM DESIGN"
2050 PRINT "ATARI 1975 / APPLE 1977"
2060 END
3000 REM -- NORMALIZE 0-360 --
3010 NR = NR - INT(NR / 360) * 360
3020 IF NR < 0 THEN NR = NR + 360
3030 RETURN
