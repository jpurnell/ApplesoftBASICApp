10 REM ================================
20 REM   GUESS THE NUMBER
30 REM   CLASSIC APPLE II GAME
40 REM ================================
50 HOME
60 PRINT "** GUESS THE NUMBER **"
70 PRINT
80 PRINT "I'M THINKING OF A NUMBER"
90 PRINT "BETWEEN 1 AND 100."
100 PRINT
110 LET N = INT(RND(1) * 100) + 1
120 LET G = 0
130 LET MX = 7
140 PRINT "YOU HAVE ";MX;" GUESSES."
150 PRINT
160 REM -- GAME LOOP --
170 LET G = G + 1
180 IF G > MX THEN GOTO 300
190 PRINT "GUESS #";G;": ";
200 INPUT "";A
210 IF A < 1 OR A > 100 THEN PRINT "BETWEEN 1 AND 100!": GOTO 170
220 IF A = N THEN GOTO 260
230 IF A < N THEN PRINT "TOO LOW!"
240 IF A > N THEN PRINT "TOO HIGH!"
250 GOTO 170
260 REM -- WIN --
270 PRINT
280 PRINT "*** CORRECT! ***"
290 PRINT "YOU GOT IT IN ";G;" GUESSES!"
295 GOTO 320
300 REM -- LOSE --
310 PRINT : PRINT "SORRY! THE NUMBER WAS ";N
320 PRINT
330 PRINT "PLAY AGAIN? (Y/N) ";
340 GET A$
350 PRINT A$
360 IF A$ = "Y" OR A$ = "y" THEN 50
370 PRINT : PRINT "THANKS FOR PLAYING!"
380 END
